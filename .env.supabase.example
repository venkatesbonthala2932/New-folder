# ============================================================
#  AADITYAA HOSPITAL — Environment Variables TEMPLATE
#  1. Copy this file:  copy .env.supabase.example .env
#  2. Fill in YOUR real values below
#  3. Save as .env  (already in .gitignore — never pushed to GitHub)
#  NEVER put real keys in this file — it IS committed to GitHub!
# ============================================================

# ── Flask ────────────────────────────────────────────────────
# WHY? Used to sign sessions internally by Flask. Make it long and random.
SECRET_KEY=REPLACE_WITH_A_RANDOM_STRING_LIKE_aadityaa-hospital-2026

# ── Supabase ─────────────────────────────────────────────────
# Get both from: Supabase Dashboard → Settings → API

# Your project URL (safe to share)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Service role key — FULL ACCESS. NEVER put this in HTML/JS frontend.
# Only use in Flask backend (server-side code).
SUPABASE_SERVICE_KEY=sb_secret_REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# Anon key — LIMITED ACCESS (frontend-safe, okay to expose in HTML/JS)
SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_YOUR_ANON_KEY

# ── Gmail Email ──────────────────────────────────────────────
# WHY? Used to send appointment confirmation emails via Gmail SMTP.
# Get app password from: Google Account → Security → App Passwords
MAIL_USERNAME=your-email@gmail.com
MAIL_APP_PASSWORD=your-16-character-gmail-app-password
