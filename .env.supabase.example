# ── Flask ────────────────────────────────────────────────────
# WHY? Used to sign JWT cookies internally by Flask. Keep it random.
SECRET_KEY=sb_secret_REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# ── Supabase ─────────────────────────────────────────────────
# Get both from: Supabase Dashboard → Settings → API

# Your project URL (safe to share)
SUPABASE_URL='https://adxylnurovyjsfccofhd.supabase.co'

# Service role key — FULL ACCESS. NEVER put this in HTML/JS frontend.
# Only use in Flask backend (server-side code).
SUPABASE_SERVICE_KEY=sb_secret_REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# Anon key — LIMITED ACCESS (for frontend HTML/JS only — safe to expose)
# Used in hospital_page.html JavaScript for Supabase Auth client-side
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY_HERE

# ── Gmail Email (unchanged) ──────────────────────────────────
# WHY still needed? Supabase doesn't send custom HTML emails with your branding.
# We keep Gmail SMTP for appointment confirmation emails.
MAIL_USERNAME=venkateshbonthala8055@gmail.com
MAIL_APP_PASSWORD=your-16-character-gmail-app-password
